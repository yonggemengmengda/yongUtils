{
	"name": "yongutils",
	"displayName": "YongUtils",
	"description": "面向前端开发者的 VS Code 效率插件，集成 Import 排序、AI 翻译、i18n 提取、类型生成、Vue 3 AST 洞察与常用开发工具",
	"version": "0.1.0",
	"author": "勇哥 <846864051@qq.com>",
	"publisher": "yonggemengmengda",
	"license": "MIT",
	"icon": "media/marketplace-icon.png",
	"homepage": "https://github.com/yonggemengmengda/yongUtils",
	"bugs": {
		"url": "https://github.com/yonggemengmengda/yongUtils/issues"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/yonggemengmengda/yongUtils.git"
	},
	"engines": {
		"vscode": "^1.92.0"
	},
	"categories": [
		"Other",
		"Formatters"
	],
	"keywords": [
		"frontend",
		"import-sort",
		"translation",
		"i18n",
		"typescript",
		"javascript",
		"vue3",
		"ast",
		"regex",
		"productivity"
	],
	"activationEvents": [
		"onCommand:yongutils.createEnglishFile",
		"onCommand:yongutils.sortImports",
		"onCommand:yongutils.translateEN",
		"onCommand:yongutils.translate",
		"onCommand:yongutils.parseToTs",
		"onCommand:yongutils.generateEnglishNames",
		"onCommand:yongutils.extractI18nEntry",
		"onCommand:yongutils.encodeURIComponent",
		"onCommand:yongutils.decodeURIComponent",
		"onCommand:yongutils.translateToggle",
		"onCommand:yongutils.openToolPanel",
		"onCommand:yongutils.debugLogger",
		"onView:yongUtils.webview"
	],
	"main": "./dist/extension.js",
	"contributes": {
		"commands": [
			{
				"command": "yongutils.createEnglishFile",
				"title": "添加英文文件"
			},
			{
				"command": "yongutils.sortImports",
				"title": "排序Imports"
			},
			{
				"command": "yongutils.translateEN",
				"title": "翻译选中为英文"
			},
			{
				"command": "yongutils.translate",
				"title": "选中英汉互译"
			},
			{
				"command": "yongutils.parseToTs",
				"title": "解析为ts类型"
			},
			{
				"command": "yongutils.generateEnglishNames",
				"title": "生成英文命名候选"
			},
			{
				"command": "yongutils.extractI18nEntry",
				"title": "提取为i18n文案"
			},
			{
				"command": "yongutils.encodeURIComponent",
				"title": "encodeURI"
			},
			{
				"command": "yongutils.decodeURIComponent",
				"title": "decodeURI"
			},
			{
				"command": "yongutils.translateToggle",
				"title": "AI自动翻译开关"
			},
			{
				"command": "yongutils.openToolPanel",
				"title": "打开 YongUtils 工具面板"
			},
			{
				"command": "yongutils.debugLogger",
				"title": "插入调试日志"
			}
		],
		"keybindings": [
			{
				"command": "yongutils.translateToggle",
				"key": "alt+y",
				"when": "editorTextFocus"
			},
			{
				"command": "yongutils.debugLogger",
				"key": "ctrl+y",
				"when": "editorTextFocus"
			}
		],
		"viewsContainers": {
			"activitybar": [
				{
					"id": "yongutils",
					"title": "YongUtils",
					"icon": "media/logo.svg"
				}
			]
		},
		"views": {
			"yongutils": [
				{
					"icon": "media/logo.svg",
					"type": "webview",
					"id": "yongUtils.webview",
					"name": "YongUtils 工具集"
				}
			]
		},
		"menus": {
			"editor/context": [
				{
					"command": "yongutils.sortImports",
					"group": "navigation",
					"when": "editorLangId == javascript || editorLangId == javascriptreact || editorLangId == typescript || editorLangId == typescriptreact || editorLangId == vue"
				},
				{
					"command": "yongutils.translateEN",
					"group": "navigation"
				},
				{
					"command": "yongutils.translate",
					"group": "navigation"
				},
				{
					"command": "yongutils.parseToTs",
					"group": "navigation"
				},
				{
					"command": "yongutils.generateEnglishNames",
					"group": "navigation"
				},
				{
					"command": "yongutils.extractI18nEntry",
					"group": "navigation"
				},
				{
					"command": "yongutils.encodeURIComponent",
					"group": "navigation"
				},
				{
					"command": "yongutils.decodeURIComponent",
					"group": "navigation"
				}
			],
			"explorer/context": [
				{
					"command": "yongutils.createEnglishFile",
					"group": "navigation",
					"when": "explorerResourceIsFolder || explorerResourceIsFile"
				}
			]
		},
		"configuration": {
			"title": "yongUtilsConfiguration",
			"properties": {
				"yongutils.importSorter.addGroupComments": {
					"type": "boolean",
					"default": true,
					"description": "添加分组注释"
				},
				"yongutils.importSorter.sortByLength": {
					"type": "boolean",
					"default": false,
					"description": "按分块由短到长排序"
				},
				"yongutils.importSorter.sortOnSave": {
					"type": "boolean",
					"default": false,
					"description": "保存文件时自动整理 import"
				},
				"yongutils.importSorter.removeUnusedImports": {
					"type": "boolean",
					"default": true,
					"description": "整理 import 时同时移除未使用的导入"
				},
				"yongutils.importSorter.placeSideEffectImportsFirst": {
					"type": "boolean",
					"default": true,
					"description": "将副作用 import 固定排在最前面"
				},
				"yongutils.importSorter.internalLibPrefixes": {
					"type": "array",
					"default": [
						"@@@/",
						"@@/",
						"@/",
						"~/"
					],
					"description": "项目内部 alias 前缀，用于区分第三方依赖和本地别名模块"
				},
				"yongutils.importSorter.customGroupNames": {
					"type": "object",
					"default": {
						"side-effect": "副作用导入",
						"builtin": "Node.js 内置模块",
						"external": "第三方依赖",
						"internal-alias": "项目别名模块",
						"parent": "父级目录模块",
						"sibling": "同级目录模块",
						"index": "Index 模块"
					},
					"description": "自定义分组注释名称"
				}
			}
		}
	},
	"scripts": {
		"vscode:prepublish": "pnpm run package",
		"compile": "webpack",
		"watch": "webpack --watch",
		"package": "webpack --mode production --devtool hidden-source-map",
		"compile-tests": "tsc -p . --outDir out",
		"watch-tests": "tsc -p . -w --outDir out",
		"pretest": "pnpm run compile-tests && pnpm run compile && pnpm run lint",
		"lint": "eslint src --ext ts",
		"test": "vscode-test"
	},
	"devDependencies": {
		"@types/babel__traverse": "^7.20.7",
		"@types/mocha": "^10.0.7",
		"@types/node": "20.x",
		"@types/vscode": "^1.92.0",
		"@typescript-eslint/eslint-plugin": "^7.14.1",
		"@typescript-eslint/parser": "^7.11.0",
		"@vscode/test-cli": "^0.0.9",
		"@vscode/test-electron": "^2.4.0",
		"eslint": "^8.57.0",
		"ts-loader": "^9.5.1",
		"typescript": "^5.4.5",
		"webpack": "^5.92.1",
		"webpack-cli": "^5.1.4"
	},
	"dependencies": {
		"@babel/parser": "^7.27.0",
		"@babel/traverse": "^7.27.0",
		"@vue/compiler-sfc": "^3.5.13",
		"chalk": "^5.3.0",
		"co": "^4.6.0",
		"compress-image": "^0.0.1",
		"filesize.js": "^2.0.0",
		"imageinfo": "^1.0.4",
		"jimp": "^1.6.0",
		"openai": "^4.77.0",
		"parse5": "^7.2.1",
		"postcss": "^8.5.3",
		"tinify": "^1.7.1"
	}
}
